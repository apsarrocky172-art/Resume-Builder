PORT=5000
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Local LM Configuration (e.g., LM Studio, Ollama)
# If LOCAL_LM_URL is provided, it will override the simulation mode and connect to your local model.
# LM Studio default is http://localhost:1234/v1
# Ollama default is http://localhost:11434/v1
LOCAL_LM_URL=http://localhost:1234/v1
LOCAL_LM_MODEL=local-model

# Google Gemini Cloud LLM (Replaces LM Studio/Ollama)
GEMINI_API_KEY=your_gemini_api_key_here
